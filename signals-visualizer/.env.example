VITE_APP_NAME=Signals Visualizer
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Edge function names in your Supabase project
VITE_BILLING_STATUS_FUNCTION=billing-status
VITE_RAZORPAY_CHECKOUT_FUNCTION=create-razorpay-checkout
VITE_RAZORPAY_MANAGE_FUNCTION=get-razorpay-manage-link

# Optional fallback links (useful before serverless functions are ready)
VITE_RAZORPAY_CHECKOUT_LINK=
VITE_RAZORPAY_MANAGE_LINK=

# Optional demo account for presentations.
# When the signed-in user's email matches VITE_DEMO_PRO_EMAIL,
# the app grants Pro access without a billing lookup.
VITE_DEMO_PRO_EMAIL=
VITE_DEMO_PRO_PASSWORD=
